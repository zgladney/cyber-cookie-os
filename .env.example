# CyberCookieOS — OAuth Credentials Template
# Copy this file to .env and fill in your real credentials.
# NEVER commit .env to git — it is listed in .gitignore.

# ── Google OAuth ──────────────────────────────────────────────────────────────
# Covers: Google Calendar, Gmail, Google Drive
# Setup: https://console.cloud.google.com → APIs & Services → Credentials
# Create an OAuth 2.0 Client ID (Desktop app or Web app)
# Add these redirect URIs in the Google Cloud Console:
#   http://localhost:8080/api/auth/google_calendar/callback
#   http://localhost:8080/api/auth/gmail/callback
#   http://localhost:8080/api/auth/google_drive/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8080/api/auth/google_calendar/callback

# ── GitHub OAuth ──────────────────────────────────────────────────────────────
# Setup: https://github.com/settings/developers → OAuth Apps → New OAuth App
# Callback URL: http://localhost:8080/api/auth/github/callback

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/api/auth/github/callback

# ── Etsy OAuth ────────────────────────────────────────────────────────────────
# Setup: https://www.etsy.com/developers/register
# Callback URL: http://localhost:8080/api/auth/etsy/callback

ETSY_CLIENT_ID=
ETSY_CLIENT_SECRET=
ETSY_REDIRECT_URI=http://localhost:8080/api/auth/etsy/callback

# ── TikTok OAuth ──────────────────────────────────────────────────────────────
# Setup: https://developers.tiktok.com → Manage Apps
# Callback URL: http://localhost:8080/api/auth/tiktok/callback

TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:8080/api/auth/tiktok/callback

# ── Local Services ────────────────────────────────────────────────────────────
# No credentials needed for Housing Scout or Finance — both are local only.
